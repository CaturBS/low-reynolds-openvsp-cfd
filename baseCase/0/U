FoamFile
{
    version 2.0;
    format ascii;
    class volVectorField;
    object U;
}

dimensions [0 1 -1 0 0 0 0];

internalField uniform (INLET_UX 0 INLET_UZ);

boundaryField
{
    inlet
    {
        type fixedValue;
        value uniform (INLET_UX 0 INLET_UZ);
    }

    outlet
    {
        type zeroGradient;
    }

    sides
    {
        type slip;
    }

    wing
    {
        type noSlip;
    }
}
