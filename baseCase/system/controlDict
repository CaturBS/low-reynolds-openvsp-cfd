FoamFile
{
    version 2.0;
    format ascii;
    class dictionary;
    object controlDict;
}

application simpleFoam;

startFrom startTime;

startTime 0;

stopAt endTime;

endTime 1000;

deltaT 1;

writeControl timeStep;

writeInterval 100;

purgeWrite 0;

writeFormat ascii;

writePrecision 6;

runTimeModifiable true;

functions
{
    forces
    {
        type            forces;
        libs            ("libforces.so");

        patches         (wing);

        rho             rhoInf;
        rhoInf          1.225;

        CofR            (0 0 0);

        writeControl    timeStep;
        writeInterval   1;
    }
forceCoeffs
  {
    type            forceCoeffs;
    libs            ("libforces.so");

    patches         (wing);

    rho             rhoInf;
    rhoInf          1.225;

    CofR            (0 0 0);

    liftDir         (LIFTX 0 LIFTZ);
    dragDir         (DRAGX 0 DRAGZ);
    pitchAxis       (0 1 0);

    magUInf         2.0;
    
    lRef            LREF;
    Aref            AREF;

    writeControl    timeStep;
    writeInterval   1;
  }
}
