FoamFile
{
    version 2.0;
    format ascii;
    class dictionary;
    object controlDict;
}

application simpleFoam;

startFrom startTime;

startTime 0;

stopAt endTime;

endTime 100;

deltaT 1;

writeControl timeStep;

writeInterval 100;

purgeWrite 0;

writeFormat ascii;

writePrecision 6;

runTimeModifiable true;

functions
{
forceCoeffs
  {
    type            forceCoeffs;
    libs            ("libforces.so");

    patches         (wing);

    rho             rhoInf;
    rhoInf          1.225;

    CofR            (0 0 0);

    liftDir         (0 0 1);
    dragDir         (1 0 0);
    pitchAxis       (0 1 0);

    magUInf         2.0;

    lRef            0.08;
    Aref            0.04;

    writeControl    timeStep;
    writeInterval   1;
  }
}
